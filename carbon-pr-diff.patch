+        </cds-combo-box>
+      `);
+
+      expect(el.value).to.equal('custom-value');
+      expect(getInput(el).value).to.equal('custom-value');
+
+      // Clear value externally
+      el.value = '';
+      await waitForUpdates(el);
+
+      expect(el.value).to.equal('');
+      expect(getInput(el).value).to.equal('');
+    });
